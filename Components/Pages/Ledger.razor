@page "/ledger"
@rendermode InteractiveServer

<div class="ledger-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="font-weight: 800; margin: 0;">가계부</h2>
        <div class="d-flex gap-2">
            <div class="dm-card d-flex align-items-center py-2 px-3" style="font-size: 0.9rem; color: #888;">
                <i class="bi bi-calendar3 me-2"></i> 2026-02-27 <i class="bi bi-chevron-down ms-2"></i>
            </div>
            <button class="dm-button-gold">+ 거래 추가</button>
        </div>
    </div>

    <!-- Summary Charts Section -->
    <div class="row g-4 mb-4">
        <!-- Left Stats -->
        <div class="col-md-3">
            <div class="dm-card dm-card-gold mb-4" style="height: 140px; position: relative;">
                <div style="font-size: 0.9rem; opacity: 0.8;">이번 달 수입</div>
                <div style="font-size: 1.8rem; font-weight: 800; margin-top: 10px;">105,000,000 <span style="font-size: 0.9rem;">MESO</span></div>
                <span class="dm-badge-up" style="position: absolute; top: 15px; right: 20px; background: rgba(255,255,255,0.2); color: white;">UP</span>
            </div>
            <div class="dm-card" style="height: 140px; position: relative;">
                <div style="font-size: 0.9rem; color: #888;">이번 달 지출</div>
                <div style="font-size: 1.8rem; font-weight: 800; margin-top: 10px;">98,500,000 <span style="font-size: 0.9rem;">MESO</span></div>
                <span class="dm-badge-up" style="position: absolute; top: 15px; right: 20px;">UP</span>
            </div>
        </div>

        <!-- Middle Bar Chart -->
        <div class="col-md-6">
            <div class="dm-card" style="height: 304px;">
                <div style="font-size: 0.9rem; font-weight: 700; margin-bottom: 20px;">일별 수입 vs 지출</div>
                <div style="height: 200px; display: flex; align-items: flex-end; gap: 15px; padding-left: 20px;">
                    @for (int i = 0; i < 12; i++)
                    {
                        var h = new[] { 60, 80, 40, 30, 70, 90, 50, 65, 75, 85, 55, 45 }[i];
                        <div style="flex: 1; background: var(--maple-gold-dim); height: @(h)%; border-radius: 4px 4px 0 0; position: relative;">
                             <div style="position: absolute; bottom: -25px; left: 50%; transform: translateX(-50%); font-size: 0.7rem; color: #444;">@(i)월</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Right Pie Chart -->
        <div class="col-md-3">
            <div class="dm-card" style="height: 304px; display: flex; flex-direction: column; align-items: center; justify-content: center;">
                <div style="font-size: 0.9rem; font-weight: 700; width: 100%; text-align: left; margin-bottom: 10px;">지출 카테고리 요약</div>
                <svg width="160" height="160" viewBox="0 0 100 100">
                    <circle cx="50" cy="50" r="40" fill="none" stroke="#222" stroke-width="20" />
                    <circle cx="50" cy="50" r="40" fill="none" stroke="var(--maple-gold)" stroke-width="20" stroke-dasharray="125, 251" stroke-dashoffset="0" />
                    <circle cx="50" cy="50" r="40" fill="none" stroke="#b86d1f" stroke-width="20" stroke-dasharray="60, 251" stroke-dashoffset="-125" />
                </svg>
            </div>
        </div>
    </div>

    <!-- Recent Transactions -->
    <h4 style="font-weight: 700; margin-bottom: 20px;">최근 거래 내역</h4>
    <div class="dm-card p-0 overflow-hidden">
        <table class="dm-table w-100">
            <thead>
                <tr>
                    <th>일간</th>
                    <th>거래 세역</th>
                    <th>너위</th>
                    <th class="text-end">수입 안탁</th>
                    <th class="text-center">UNIT</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in _transactions)
                {
                    <tr>
                        <td style="color: #888;">@item.Date</td>
                        <td>
                            @item.Title 
                            <span class="@(item.IsUp ? "dm-badge-up" : "dm-badge-down") ms-2">UP</span>
                        </td>
                        <td>@(item.IsIncome ? "수입" : "지출")</td>
                        <td class="text-end" style="font-weight: 700;">
                            @item.Amount.ToString("N0") <span style="font-size: 0.7rem; color: #666; font-weight: 400;">MESO</span>
                        </td>
                        <td class="text-center">
                            <div style="display: inline-flex; align-items: center; background: #222; padding: 2px 10px; border-radius: 20px; font-size: 0.8rem;">
                                <img src="favicon.png" width="14" class="me-2" /> @item.Unit
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .dm-table { border-collapse: collapse; }
    .dm-table th { padding: 15px 20px; color: #444; font-size: 0.8rem; text-transform: uppercase; border-bottom: 1px solid #222; }
    .dm-table td { padding: 18px 20px; border-bottom: 1px solid #1a1a1a; font-size: 0.95rem; }
    .dm-table tr:last-child td { border-bottom: none; }
</style>

@code {
    private List<Transaction> _transactions = new()
    {
        new("2026-02-27", "경매장 판매", true, true, 2305000, "12.5B"),
        new("2026-02-26", "스타포스 강화", false, false, 1500000, "12.5B"),
        new("2026-02-25", "사냥 수익", true, true, 1800000, "12.5B"),
        new("2026-02-24", "코디 구매", false, false, 3000000, "12.5B"),
        new("2026-02-23", "젬스톤 판매", true, true, 4500000, "12.5B")
    };

    private record Transaction(string Date, string Title, bool IsUp, bool IsIncome, double Amount, string Unit);
}
