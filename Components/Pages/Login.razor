@page "/login"
@rendermode InteractiveServer
@using MapleStoryMarketGraph.Models
@using MapleStoryMarketGraph.Services
@inject AuthService AuthService
@inject GoogleAuthService GoogleAuthService
@inject JwtAuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject IConfiguration Config
@inject IJSRuntime JS
@implements IDisposable

<div class="auth-container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="dm-card auth-card" style="width: 100%; max-width: 450px;">
        <h2 class="text-center mb-4" style="color: var(--maple-gold); font-weight: 800;">로그인</h2>

        <div class="mb-4 d-flex justify-content-center">
            <div id="google-button-container" style="width: 100%;"></div>
        </div>

        <div class="d-flex align-items-center gap-3 mb-4">
            <hr class="flex-grow-1" style="border-color: #333;">
            <span style="color: #666; font-size: 0.85rem;">또는 이메일로 로그인</span>
            <hr class="flex-grow-1" style="border-color: #333;">
        </div>

        <EditForm Model="@_request" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />

            <div class="mb-3">
                <label class="form-label" style="color: var(--text-gray); font-weight: 500;">이메일</label>
                <InputText @bind-Value="_request.Email" class="form-control dm-input" placeholder="example@email.com" />
            </div>

            <div class="mb-4">
                <label class="form-label" style="color: var(--text-gray); font-weight: 500;">비밀번호</label>
                <InputText @bind-Value="_request.Password" type="password" class="form-control dm-input"
                           placeholder="비밀번호" />
            </div>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert alert-danger py-2 mb-4"
                     style="font-size: 0.9rem; background: rgba(220,53,69,0.1); border-color: rgba(220,53,69,0.3); color: #ff6b6b; border-radius: 8px;">
                    @_errorMessage</div>
                }

                <button type="submit" class="dm-button-gold w-100 py-3 mb-3"
                        style="font-size: 1.1rem; border-radius: 12px; font-weight: 700;">
                    로그인
                </button>
            </EditForm>

            <div class="text-center mt-4" style="font-size: 0.95rem; color: var(--text-gray);">
                아직 계정이 없으신가요? <a href="/register"
                                 style="color: var(--maple-gold); text-decoration: none; font-weight: 600; margin-left: 5px;">회원가입</a>
            </div>
        </div>
    </div>

    <style>
        .dm-input {
            background: #111;
            border: 1px solid #333;
            color: white;
            padding: 14px;
            border-radius: 12px;
            transition: all 0.2s ease-in-out;
        }

        .dm-input:focus {
            background: #1a1a1a;
            border-color: var(--maple-gold);
            color: white;
            box-shadow: 0 0 0 2px rgba(242, 145, 50, 0.2);
        }

        .auth-card {
            padding: 40px !important;
            border-radius: 20px !important;
            background: #0a0a0a !important;
            border: 1px solid #222 !important;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        }
    </style>

@code {
    private LoginRequest _request = new();
    private string? _errorMessage;
    private DotNetObjectReference<Login>? _dotNetHelper;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetHelper = DotNetObjectReference.Create(this);
            var clientId = Config["Authentication:Google:ClientId"];
            if (!string.IsNullOrEmpty(clientId) && clientId != "YOUR_GOOGLE_CLIENT_ID")
            {
                await JS.InvokeVoidAsync("initializeGoogleLogin", _dotNetHelper, clientId);
            }
            else
            {
                _errorMessage = "Google Client ID가 설정되지 않아 구글 로그인을 사용할 수 없습니다.";
                StateHasChanged();
            }
        }
    }

    private async Task HandleLogin()
    {
        _errorMessage = null;
        try
        {
            var (success, message, token) = await AuthService.LoginLocalAsync(_request.Email, _request.Password);
            if (success && !string.IsNullOrEmpty(token))
            {
                await AuthStateProvider.MarkUserAsAuthenticated(token);
                Navigation.NavigateTo("/");
            }
            else
            {
                _errorMessage = message;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"오류가 발생했습니다: {ex.Message}";
        }
    }

    [JSInvokable]
    public async Task HandleGoogleCredential(string credential)
    {
        _errorMessage = null;
        try
        {
            var (success, message, token) = await GoogleAuthService.AuthenticateWithGoogleAsync(credential);
            if (success && !string.IsNullOrEmpty(token))
            {
                await AuthStateProvider.MarkUserAsAuthenticated(token);
                Navigation.NavigateTo("/");
            }
            else
            {
                _errorMessage = message;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"오류가 발생했습니다: {ex.Message}";
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        _dotNetHelper?.Dispose();
    }
}