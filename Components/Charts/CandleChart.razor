@using TeruTeruPandas.Core
@using System.Globalization

<div class="candle-chart-wrapper" style="width: 100%; height: 100%; display: flex; flex-direction: column;">
    <!-- Chart Area -->
    <div class="candle-chart-container"
         style="flex: 1; position: relative; background: #0a0a0a; cursor: crosshair; user-select: none; overflow: hidden;"
         @onmousemove="OnMouseMove" @onmouseleave="OnMouseLeave" @onwheel="OnWheel" @onwheel:preventDefault="true">
        
        <svg width="100%" height="100%" viewBox="0 0 @Width @Height" preserveAspectRatio="none">
            <!-- 1. Grid Lines -->
            <g class="grid-lines">
                @for (int i = 0; i <= 6; i++)
                {
                    var y = _marginTop + (_chartHeight * i / 6);
                    var price = _maxPrice - (_priceRange * i / 6);
                    <line x1="@_marginLeft" y1="@y" x2="@(_Width - _marginRight)" y2="@y" stroke="#1a1a1a" stroke-width="1" />
                    <svg:text x="@(_Width - _marginRight + 12)" y="@(y + 4)" fill="#444" font-size="11" font-weight="500">
                        @price.ToString("N0")</svg:text>
                }
            </g>

            <!-- 2. Price Histogram -->
            <g class="price-histogram">
                @if (_priceDistribution != null)
                {
                    var maxDist = _priceDistribution.Values.DefaultIfEmpty(1).Max();
                    var binCount = _priceDistribution.Count;
                    var binHeight = _chartHeight / binCount;
                    int j = 0;
                    @foreach (var entry in _priceDistribution.OrderByDescending(k => k.Key))
                    {
                        var barWidth = (entry.Value / (double)maxDist) * 110;
                        var yPos = _marginTop + (j * binHeight);
                        <rect x="@(_Width - _marginRight - barWidth)" y="@yPos" width="@barWidth" height="@(binHeight - 1)"
                              fill="#666" fill-opacity="0.15" />
                        j++;
                    }
                }
            </g>

            <!-- 3. Moving Averages -->
            <g class="ma-lines">
                @RenderMaLine($"{Unit}MA20", "#ffd700")
                @RenderMaLine($"{Unit}MA60", "#e040fb")
                @RenderMaLine($"{Unit}MA120", "#00e5ff")
            </g>

            <!-- 4. Candles -->
            <g class="candles">
                @for (int i = 0; i < _visibleCount; i++)
                {
                    var rowIdx = _startIndex + i;
                    if (rowIdx < 0 || rowIdx >= Data.RowCount) continue;

                    var open = Convert.ToDouble(Data[rowIdx, $"{Unit}Open"]);
                    var high = Convert.ToDouble(Data[rowIdx, $"{Unit}High"]);
                    var low = Convert.ToDouble(Data[rowIdx, $"{Unit}Low"]);
                    var close = Convert.ToDouble(Data[rowIdx, $"{Unit}Close"]);

                    var x = _marginLeft + (i * _candleWidth);
                    var candleBodyWidth = _candleWidth * 0.7;

                    var yHigh = PriceToY(high);
                    var yLow = PriceToY(low);
                    var yOpen = PriceToY(open);
                    var yClose = PriceToY(close);

                    var bodyY = Math.Min(yOpen, yClose);
                    var bodyHeight = Math.Max(1, Math.Abs(yOpen - yClose));
                    var color = close >= open ? "#4CAF50" : "#FF5252";

                    <line x1="@(x + candleBodyWidth / 2)" y1="@yHigh" x2="@(x + candleBodyWidth / 2)" y2="@yLow" stroke="@color" stroke-width="1.2" />
                    <rect x="@x" y="@bodyY" width="@candleBodyWidth" height="@bodyHeight" fill="@color" fill-opacity="0.8" />
                }
            </g>

            <!-- 5. Crosshair -->
            @if (_hoverIndex >= 0)
            {
                var hX = _marginLeft + (_hoverIndex * _candleWidth) + (_candleWidth * 0.35);
                <line x1="@hX" y1="@_marginTop" x2="@hX" y2="@(_Height - _marginBottom)" stroke="rgba(255,255,255,0.15)" stroke-dasharray="4" />
            }
        </svg>

        <!-- Tooltip -->
        @if (_hoverIndex >= 0 && _hoverData != null)
        {
            <div class="chart-tooltip" 
                 style="position: absolute; left: @(_tooltipX)px; top: 30px; background: rgba(0,0,0,0.9); border: 1px solid #333; padding: 15px; border-radius: 10px; pointer-events: none; z-index: 100; box-shadow: 0 10px 40px rgba(0,0,0,0.5);">
                <div style="color: var(--maple-gold); font-weight: 800; font-size: 14px; margin-bottom: 10px; border-bottom: 1px solid #222; padding-bottom: 5px;">@_hoverData.Date</div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; font-size: 13px;">
                    <span style="color: #666;">Open:</span> <span>@_hoverData.Open.ToString("N0")</span>
                    <span style="color: #666;">High:</span> <span style="color: #4CAF50; font-weight: 700;">@_hoverData.High.ToString("N0")</span>
                    <span style="color: #666;">Low:</span> <span style="color: #FF5252; font-weight: 700;">@_hoverData.Low.ToString("N0")</span>
                    <span style="color: #666;">Close:</span> <strong style="color: white;">@_hoverData.Close.ToString("N0")</strong>
                </div>
            </div>
        }

        <!-- Zoom Floating Buttons -->
        <div class="zoom-controls" style="position: absolute; right: 130px; bottom: 30px; display: flex; flex-direction: column; gap: 10px;">
            <button class="zoom-btn" @onclick="() => Zoom(true)" title="확대">
                <i class="bi bi-plus-lg"></i>
            </button>
            <button class="zoom-btn" @onclick="() => Zoom(false)" title="축소">
                <i class="bi bi-dash-lg"></i>
            </button>
        </div>
    </div>

    <!-- Scrollbar & Timeline -->
    <div class="chart-footer-area" style="height: 50px; background: #080808; padding: 0 50px; display: flex; align-items: center; gap: 30px; border-top: 1px solid #1a1a1a;">
        <input type="range" 
               style="flex: 1; accent-color: var(--maple-gold); cursor: pointer; height: 4px;"
               min="0" max="@(Math.Max(0, Data.RowCount - _visibleCount))" 
               @bind="_startIndex" @bind:event="oninput" @onchange="OnScrollChange" />
    </div>
</div>

<style>
    .zoom-btn {
        width: 44px; height: 44px; background: rgba(0,0,0,0.7); border: 1px solid #333;
        color: var(--maple-gold); border-radius: 50%; display: flex; align-items: center; justify-content: center;
        font-size: 1.2rem; cursor: pointer; transition: all 0.2s; box-shadow: 0 4px 15px rgba(0,0,0,0.3);
    }
    .zoom-btn:hover { background: #222; border-color: var(--maple-gold); transform: scale(1.05); }
    .zoom-btn:active { transform: scale(0.95); }
</style>

@code {
    [Parameter] public DataFrame Data { get; set; } = default!;
    [Parameter] public string Unit { get; set; } = "1억";
    [Parameter] public double Width { get; set; } = 1600;
    [Parameter] public double Height { get; set; } = 800;

    private double _Width => Width;
    private double _Height => Height;
    private double _marginLeft = 20;
    private double _marginRight = 100;
    private double _marginTop = 20;
    private double _marginBottom = 20;
    private double _chartWidth => _Width - _marginLeft - _marginRight;
    private double _chartHeight => _Height - _marginTop - _marginBottom;

    private int _startIndex = 0;
    private int _visibleCount = 100;
    private double _candleWidth => _chartWidth / Math.Max(1, _visibleCount);
    
    private double _minPrice, _maxPrice, _priceRange;
    private Dictionary<double, int> _priceDistribution = new();
    private int _hoverIndex = -1;
    private double _tooltipX = 0;
    private CandleData? _hoverData;

    protected override void OnParametersSet()
    {
        if (Data != null && Data.RowCount > 0)
        {
            if (_startIndex + _visibleCount > Data.RowCount || _startIndex < 0)
            {
                _visibleCount = Math.Min(Data.RowCount, 100);
                _startIndex = Data.RowCount - _visibleCount;
            }
            UpdateChart();
        }
    }

    private void UpdateChart()
    {
        if (Data == null || Data.RowCount == 0) return;
        _visibleCount = Math.Clamp(_visibleCount, 10, Data.RowCount);
        if (_startIndex + _visibleCount > Data.RowCount) _startIndex = Math.Max(0, Data.RowCount - _visibleCount);
        CalculateScale();
        CalculatePriceDistribution();
    }

    private void CalculateScale()
    {
        _minPrice = double.MaxValue; _maxPrice = double.MinValue;
        for (int i = 0; i < _visibleCount; i++)
        {
            var idx = _startIndex + i;
            if (idx < 0 || idx >= Data.RowCount) continue;
            _minPrice = Math.Min(_minPrice, Convert.ToDouble(Data[idx, $"{Unit}Low"]));
            _maxPrice = Math.Max(_maxPrice, Convert.ToDouble(Data[idx, $"{Unit}High"]));
            CheckMaScale(idx, $"{Unit}MA20");
            CheckMaScale(idx, $"{Unit}MA60");
            CheckMaScale(idx, $"{Unit}MA120");
        }
        var padding = (_maxPrice - _minPrice) * 0.12;
        _maxPrice += padding; _minPrice -= padding;
        _priceRange = Math.Max(1, _maxPrice - _minPrice);
    }

    private void CheckMaScale(int idx, string col)
    {
        var val = Data[idx, col];
        if (val != null && !val.ToString()!.Equals("NaN"))
        {
            var dVal = Convert.ToDouble(val);
            _minPrice = Math.Min(_minPrice, dVal); _maxPrice = Math.Max(_maxPrice, dVal);
        }
    }

    private RenderFragment RenderMaLine(string col, string color) => builder =>
    {
        string pts = ""; bool first = true;
        for (int i = 0; i < _visibleCount; i++)
        {
            var rowIdx = _startIndex + i;
            if (rowIdx < 0 || rowIdx >= Data.RowCount) continue;
            var val = Data[rowIdx, col];
            if (val == null || val.ToString()!.Equals("NaN")) continue;
            var x = _marginLeft + (i * _candleWidth) + (_candleWidth * 0.35);
            var y = PriceToY(Convert.ToDouble(val));
            if (first) { pts = $"{x.ToString(CultureInfo.InvariantCulture)},{y.ToString(CultureInfo.InvariantCulture)}"; first = false; }
            else { pts += $" {x.ToString(CultureInfo.InvariantCulture)},{y.ToString(CultureInfo.InvariantCulture)}"; }
        }
        if (!string.IsNullOrEmpty(pts))
        {
            builder.OpenElement(0, "polyline");
            builder.AddAttribute(1, "points", pts);
            builder.AddAttribute(2, "fill", "none");
            builder.AddAttribute(3, "stroke", color);
            builder.AddAttribute(4, "stroke-width", "1");
            builder.CloseElement();
        }
    };

    private void CalculatePriceDistribution()
    {
        _priceDistribution.Clear();
        int bins = 25; double binSize = _priceRange / bins;
        for (int i = 0; i < _visibleCount; i++)
        {
            var idx = _startIndex + i;
            if (idx < 0 || idx >= Data.RowCount) continue;
            var close = Convert.ToDouble(Data[idx, $"{Unit}Close"]);
            var binKey = Math.Floor((close - _minPrice) / binSize) * binSize + _minPrice;
            if (!_priceDistribution.ContainsKey(binKey)) _priceDistribution[binKey] = 0;
            _priceDistribution[binKey]++;
        }
    }

    private double PriceToY(double p) => _marginTop + _chartHeight - ((p - _minPrice) / _priceRange * _chartHeight);

    private void Zoom(bool zoomIn)
    {
        int oldVisible = _visibleCount;
        int step = Math.Max(2, (int)(_visibleCount * 0.2));
        
        if (zoomIn) _visibleCount = Math.Max(10, _visibleCount - step);
        else _visibleCount = Math.Min(Data.RowCount, _visibleCount + step);

        // 마지막 캔들이 화면의 같은 지점에 머물도록 _startIndex 보정
        _startIndex = _startIndex + (oldVisible - _visibleCount);
        UpdateChart();
    }

    private void OnWheel(WheelEventArgs e) => Zoom(e.DeltaY < 0);

    private void OnScrollChange() => UpdateChart();

    private void OnMouseMove(MouseEventArgs e)
    {
        if (Data == null || Data.RowCount == 0) return;
        var relX = e.OffsetX - _marginLeft;
        if (relX < 0 || relX > _chartWidth) { _hoverIndex = -1; return; }
        _hoverIndex = (int)(relX / _candleWidth);
        if (_hoverIndex >= 0 && _hoverIndex < _visibleCount)
        {
            var rowIdx = _startIndex + _hoverIndex;
            if (rowIdx >= 0 && rowIdx < Data.RowCount)
            {
                _hoverData = new CandleData {
                    Date = Data?[rowIdx, $"{Unit}Date"]?.ToString() ?? "",
                    Open = Convert.ToDouble(Data?[rowIdx, $"{Unit}Open"] ?? 0),
                    High = Convert.ToDouble(Data?[rowIdx, $"{Unit}High"] ?? 0),
                    Low = Convert.ToDouble(Data?[rowIdx, $"{Unit}Low"] ?? 0),
                    Close = Convert.ToDouble(Data?[rowIdx, $"{Unit}Close"] ?? 0)
                };
                _tooltipX = e.OffsetX + 15;
                if (_tooltipX > _Width - 200) _tooltipX = e.OffsetX - 210;
            }
        }
    }

    private void OnMouseLeave() => _hoverIndex = -1;

    private class CandleData { public string? Date; public double Open, High, Low, Close; }
}
